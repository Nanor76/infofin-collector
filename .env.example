# Paths are relative to the current working directory.
INFOFIN_DB_PATH=data/infofin.sqlite3
INFOFIN_DATA_DIR=data/raw
# Bulgarie: portail X3News courant + archive historique BSE
BULGARIA_X3NEWS_BASE_URL=https://www.x3news.com
# Le serveur X3News ne fournit pas actuellement une chaine TLS complete a requests.
BULGARIA_X3NEWS_VERIFY_SSL=false
BULGARIA_X3NEWS_MAX_PAGES=100
BULGARIA_BSE_X3NEWS_MAX_CANDIDATES_PER_SOURCE=200

# Webapp locale de recherche de documents.
INFOFIN_WEB_HOST=127.0.0.1
INFOFIN_WEB_PORT=8765
INFOFIN_WEB_WORKERS=2
INFOFIN_WEB_MAX_PERIOD_DAYS=370
INFOFIN_WEB_MAX_CANDIDATES=100000

# Production Google Cloud: Firestore persistence + Cloud Run Jobs or Cloud Tasks.
# Keep sqlite/local for development and the offline test suite.
INFOFIN_WEB_STORAGE_BACKEND=sqlite
INFOFIN_WEB_JOB_BACKEND=local
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=europe-west1
INFOFIN_CLOUD_RUN_JOB=infofin-search
INFOFIN_CLOUD_TASKS_QUEUE=infofin-search-queue
INFOFIN_WEB_SERVICE_URL=
INFOFIN_FIRESTORE_PREFIX=infofin_web
INFOFIN_WEB_RETENTION_DAYS=30
# Optional HTTP Basic protection. Keep the password empty for local development.
INFOFIN_WEB_ACCESS_USERNAME=infofin
INFOFIN_WEB_ACCESS_PASSWORD=
# Bêta privée : JSON de comptes hachés et secret de signature de session.
# Générer le JSON avec: python -m webapp.manage_beta --username alice
INFOFIN_BETA_USERS_JSON=
INFOFIN_BETA_SESSION_SECRET=
INFOFIN_BETA_SESSION_HOURS=168
INFOFIN_BETA_DAILY_SEARCH_LIMIT=3
# Jeton distinct utilisé uniquement par Cloud Tasks pour le worker interne.
INFOFIN_WORKER_TOKEN=
INFOFIN_CONTACT_EMAIL=
INFOFIN_LEGAL_PUBLISHER=InfoFin

HTTP_TIMEOUT_SECONDS=30
HTTP_RETRIES=3
HTTP_BACKOFF_FACTOR=0.8
HTTP_USER_AGENT=InfoFin/1.0 (+local financial disclosure monitor)
MAX_DOWNLOAD_MB=100

# Official Info-financiere OpenDataSoft portal root.
AMF_ODS_BASE_URL=https://www.info-financiere.gouv.fr
# Optional portal roots separated by semicolons and tried after the main base.
AMF_ODS_FALLBACK_BASE_URLS=https://www.info-financiere.gouv.fr;https://data.economie.gouv.fr
AMF_ODS_DATASET=flux-amf-new-prod
AMF_ODS_ROWS=100

# Official Euronext Live Oslo company regulated news page.
OSLO_EURONEXT_NEWS_URL=https://live.euronext.com/en/markets/oslo/equities/company-news
OSLO_NEWSWEB_BASE_URL=https://newsweb.oslobors.no
OSLO_RATE_LIMIT_SECONDS=0.5
OSLO_LOOKBACK_DAYS=400

# Official Italian authorized storage and discovery fallbacks.
ITALY_EMARKET_HOME_URL=https://www.emarketstorage.it/
ITALY_DOCUMENTS_URL=https://www.emarketstorage.it/it/documenti
ITALY_PRESS_RELEASES_URL=https://www.emarketstorage.it/it/comunicati-finanziari
ITALY_1INFO_URL=https://www.1info.it/PORTALE1INFO
ITALY_BORSA_COMPANY_BASE_URL=https://www.borsaitaliana.it/borsa/azioni/scheda
ITALY_RATE_LIMIT_SECONDS=0.5
ITALY_LOOKBACK_DAYS=400
ITALY_MAX_PAGES=2
ITALY_EMARKET_VERIFY_SSL=true

# Official Netherlands AFM financial reporting and home member state registers.
NETHERLANDS_AFM_REGISTER_URL=https://www.afm.nl/en/sector/registers/meldingenregisters/financiele-verslaggeving
NETHERLANDS_AFM_EXPORT_TYPE=e8825b05-4004-4301-b736-651e8c61053d
NETHERLANDS_HOME_MEMBER_STATE_URL=https://www.afm.nl/en/sector/registers/meldingenregisters/home-member-state
NETHERLANDS_HOME_MEMBER_STATE_EXPORT_TYPE=6b365727-6220-452f-83b1-86a179d70d12
NETHERLANDS_RATE_LIMIT_SECONDS=0.2
NETHERLANDS_LOOKBACK_DAYS=900

# Official Belgian storage mechanism for regulated information.
BELGIUM_FSMA_STORI_BASE_URL=https://www.fsma.be/en/stori
BELGIUM_RATE_LIMIT_SECONDS=0.2
BELGIUM_LOOKBACK_DAYS=900

# Official Portuguese CMVM / SDI regulated-information portal.
PORTUGAL_CMVM_BASE_URL=https://www.cmvm.pt/PInstitucional
PORTUGAL_CMVM_SDI_URL=https://www.cmvm.pt/PInstitucional/Content?Input=BD77C8DEEB2702712300D99098915461C2A4F65FE4368A561E6AB83D1E580C4D
PORTUGAL_RATE_LIMIT_SECONDS=0.5
PORTUGAL_LOOKBACK_DAYS=900

# Official Euronext Dublin OAM / Euronext Direct public announcements.
IRELAND_EURONEXT_DIRECT_BASE_URL=https://direct.euronext.com
IRELAND_EURONEXT_DUBLIN_URL=https://www.euronext.com/en/about-euronext/markets/dublin
IRELAND_RATE_LIMIT_SECONDS=0.5
IRELAND_LOOKBACK_DAYS=900

# Spain CNMV & BME configuration
SPAIN_CNMV_BASE_URL=https://www.cnmv.es
SPAIN_CNMV_LOOKBACK_DAYS=30
SPAIN_RATE_LIMIT_SECONDS=0.5
SPAIN_VERIFY_SSL=true
SPAIN_BME_LISTED_COMPANIES_URL=https://www.bolsasymercados.es

# Sweden FI & Nasdaq configuration
SWEDEN_FI_BASE_URL=https://borsinformation.fi.se
SWEDEN_FI_LOOKBACK_DAYS=30
SWEDEN_RATE_LIMIT_SECONDS=0.5
SWEDEN_VERIFY_SSL=true
SWEDEN_NASDAQ_LISTED_COMPANIES_URL=https://www.nasdaqomxnordic.com

# Denmark DFSA OAM and optional Nasdaq Copenhagen company mapping.
DENMARK_DFSA_BASE_URL=https://www.dfsa.dk/financial-themes/capital-market/company-announcements
DENMARK_DFSA_LOOKBACK_DAYS=30
DENMARK_RATE_LIMIT_SECONDS=0.5
DENMARK_VERIFY_SSL=true
DENMARK_NASDAQ_LISTED_COMPANIES_URL=https://www.nasdaqomxnordic.com

# Austria OeKB official OAM Issuer Info.
AUSTRIA_OEKB_FEED_URL=https://my.oekb.at/issuer-info/rest/public/meldedaten/iic
AUSTRIA_OEKB_DOWNLOAD_BASE_URL=https://my.oekb.at/issuer-info/rest/public/meldedaten/download
AUSTRIA_OEKB_ISSUER_LIST_URL=https://my.oekb.at/kapitalmarkt-services/kms-output/oamn/iic/list
AUSTRIA_OEKB_LOOKBACK_DAYS=30
AUSTRIA_OEKB_RATE_LIMIT_SECONDS=0.2
AUSTRIA_OEKB_VERIFY_SSL=true

# Poland KNF Officially Appointed Mechanism.
POLAND_KNF_OAM_BASE_URL=https://moam.knf.gov.pl/moam.nsf
POLAND_KNF_OAM_LOOKBACK_DAYS=30
POLAND_KNF_OAM_RATE_LIMIT_SECONDS=0.2
POLAND_KNF_OAM_VERIFY_SSL=true
POLAND_KNF_OAM_MAX_PAGES_PER_DATE=25
